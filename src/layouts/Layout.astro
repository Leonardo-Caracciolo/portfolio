---
import ChatWidget from '../components/ChatWidget';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Leonardo Caracciolo — Backend Developer · AI Automation',
  description = 'Backend Developer especializado en IA y automatización. Python, FastAPI, LLMs, Docker.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Leonardo Caracciolo" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <ChatWidget client:load />
  </body>
</html>
